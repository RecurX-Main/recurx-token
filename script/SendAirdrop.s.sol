    function run() external {
        // uint256 deployerPrivateKey = vm.envUint(");,
        vm.startBroadcast();

        RecurXToken token = RecurXToken(RCX_TOKEN_CONTRACT);
        TokenAirdrop airdropper = TokenAirdrop(AIRDROP_CONTRACT);

        uint256 requiredBalance = AIRDROP_AMOUNT * recipients.length;
        uint256 contractBalance = token.balanceOf(AIRDROP_CONTRACT);

        require(contractBalance >= requiredBalance, "Insufficient balance in airdrop contract");

        uint256 totalBatches = (recipients.length + BATCH_SIZE - 1) / BATCH_SIZE;

        for (uint256 i = 0; i < totalBatches; i++) {
            uint256 startIndex = i * BATCH_SIZE;
            uint256 endIndex = startIndex + BATCH_SIZE;
            if (endIndex > recipients.length) endIndex = recipients.length;

            try airdropper.airdropBatch(
                RCX_TOKEN_CONTRACT,
                recipients,
                AIRDROP_AMOUNT,
                startIndex,
                endIndex
            ) {
                console.log("Batch", i + 1);
                console.log("successful (", endIndex - startIndex, "recipients)");
            } catch Error(string memory reason) {
                console.log("Batch", i + 1, "failed:", reason);
                break; // Optional: stop on failure
            }
        }

        uint256 finalBalance = token.balanceOf(AIRDROP_CONTRACT);
        console.log("Airdrop complete.");
        console.log("Remaining balance:", finalBalance / 1e18, "RCX");
        console.log("Total distributed:", (contractBalance - finalBalance) / 1e18, "RCX");

        vm.stopBroadcast();
    }
